[node name="VegetarianExplanation2" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/VeganButton"]
visible = false
layout_mode = 0
offset_left = 426.0
offset_top = -18.0
offset_right = 1043.0
offset_bottom = 401.0
text = "Selecting this excludes dishes that include meat, poultry, seafood, dairy, eggs and all other ingredients in which animals are involved during the production. 

This includes ingredients that are considered \"by products\" such as gelatin, e120, lard, omega 3 acids, animal rennet and gelatine alternatives made from connective tissue."

