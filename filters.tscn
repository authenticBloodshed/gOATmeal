offset_top = 261.0
offset_right = 320.0
offset_bottom = 298.0
theme = ExtResource("1_hnnkf")
text = "No artificial ingredients "
script = ExtResource("2_t4aci")
explanation = NodePath("SugarsExplanation")

[node name="SugarsExplanation" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/SugarsButton"]
visible = false
layout_mode = 0
offset_left = 496.0
offset_top = -196.0
offset_right = 1034.0
offset_bottom = 223.0
text = "Selecting this excludes dishes that include artificial ingredients. All dishes under this category are flavoured using natural sugars that are naturally in the products and have no added sugars, such as fructose or honey."

[node name="Organic" type="CheckButton" parent="TabManager/TabContainer/Diet preferences" node_paths=PackedStringArray("explanation")]
layout_mode = 0
offset_left = 6.0
offset_top = 305.0
offset_right = 323.0
offset_bottom = 342.0
theme = ExtResource("1_hnnkf")
text = "Organic"
script = ExtResource("2_t4aci")
explanation = NodePath("OrganicExplanation")

[node name="OrganicExplanation" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/Organic"]
visible = false
layout_mode = 0
offset_left = 493.0
offset_top = -240.0
offset_right = 1031.0
offset_bottom = 179.0
text = "Selecting this ensures that you only see dishes made with organic ingredients. This means all ingredients included in these dishes are chemical fertilizers, pesticides, or other artificial chemicals free."

[node name="ProteinButton" type="CheckButton" parent="TabManager/TabContainer/Diet preferences" node_paths=PackedStringArray("explanation")]
layout_mode = 0
offset_left = 4.0
offset_top = 350.0
offset_right = 321.0
offset_bottom = 387.0
theme = ExtResource("1_hnnkf")
text = "High protein"
script = ExtResource("2_t4aci")
explanation = NodePath("ProteinExplanation")

[node name="ProteinExplanation" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/ProteinButton"]
visible = false
layout_mode = 0
offset_left = 495.0
offset_top = -285.0
offset_right = 1033.0
offset_bottom = 189.0
text = "Selecting this ensures that you only see dishes that are higher in protein. 

Something counts as \"high protein\" when at least 20% of its total energy comes from protein. Dishes under this category may be originally high in protein or made high protein through added ingredients such as protein powders. 

If you wish to exclude artificial proteins, adding the \"no artificial ingredients\" filter will exclude those from the results."

[node name="PlantBasedButton" type="CheckButton" parent="TabManager/TabContainer/Diet preferences" node_paths=PackedStringArray("explanation")]
layout_mode = 0
offset_left = 4.0
offset_top = 395.0
offset_right = 321.0
offset_bottom = 432.0
theme = ExtResource("1_hnnkf")
text = "Plantbased"
script = ExtResource("2_t4aci")
explanation = NodePath("PlantBasedExplanation")

[node name="PlantBasedExplanation" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/PlantBasedButton"]
visible = false
layout_mode = 0
offset_left = 495.0
offset_top = -330.0
offset_right = 1033.0
offset_bottom = 144.0
text = "Selecting this ensures that you only see dishes that are plant based. 

Something counts as \"plant based\" when it consists  solely of vegetables, grains, pulses, or other foods derived from plants, rather than animal products.

This category does not eliminate products that may have been tested on animals or include animal labour to produce. "

[node name="HalalButton" type="CheckButton" parent="TabManager/TabContainer/Diet preferences" node_paths=PackedStringArray("explanation")]
layout_mode = 0
offset_left = 4.0
offset_top = 437.0
offset_right = 321.0
offset_bottom = 474.0
theme = ExtResource("1_hnnkf")
text = "Halal"
script = ExtResource("2_t4aci")
explanation = NodePath("HalalExplanation")

[node name="HalalExplanation" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/HalalButton"]
visible = false
layout_mode = 0
offset_left = 495.0
offset_top = -372.0
offset_right = 1033.0
offset_bottom = 47.0
text = "Selecting this ensures that all dishes shown abide by the islamic law. Selecting this ensures that all products used are either halal by default, taahir or halal certified products in the case of animal products. Vegan, vegetarian or kosher dishes may be included in this category as well."

[node name="KosherButton" type="CheckButton" parent="TabManager/TabContainer/Diet preferences" node_paths=PackedStringArray("explanation")]
layout_mode = 0
offset_left = 4.0
offset_top = 479.0
offset_right = 321.0
offset_bottom = 516.0
theme = ExtResource("1_hnnkf")
text = "Kosher"
script = ExtResource("2_t4aci")
explanation = NodePath("KosherExplanation")

[node name="KosherExplanation" type="RichTextLabel" parent="TabManager/TabContainer/Diet preferences/KosherButton"]
visible = false
layout_mode = 0
offset_left = 495.0
offset_top = -414.0
offset_right = 1033.0
offset_bottom = 60.0
text = "Selecting this ensures that you only see dishes that abide by the Jewish dietary regulations of kashrut. animal derived dishes and dairy are not mixed in these dishes.

Selecting this ensures that all products used are kosher certified products in the case of animal products. 

Vegan or vegetarian may be included in this category as well, provided those dishes do not mix dairy with animal derived products."

